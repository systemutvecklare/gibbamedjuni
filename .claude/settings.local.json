{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git symbolic-ref *)",
      "Bash(git --version)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "lsof -ti:8080 >/dev/null 2>&1 || (cd /Users/gamer/repos/gibbamedjuni && nohup npx --yes live-server --port=8080 --no-browser >/tmp/jubby-live-server.log 2>&1 &)"
          }
        ]
      }
    ]
  }
}
